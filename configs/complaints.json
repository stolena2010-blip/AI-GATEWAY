{
  "profile_name": "complaints",
  "display_name": "תלונות לקוח",
  "description": "Customer complaints processing",
  "email": {
    "shared_mailbox": "",
    "shared_mailboxes": [],
    "inbox_folder": "Inbox",
    "rerun_folder_name": "",
    "rerun_mailbox": "",
    "skip_senders": [],
    "skip_categories": [
      "AI CMP DONE",
      "AI CMP ERROR"
    ],
    "scan_from_date": "",
